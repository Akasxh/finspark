# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development           # development | staging | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-256-bit-hex-string
APP_ALLOWED_HOSTS=["*"]

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default for local dev)
DATABASE_URL=sqlite+aiosqlite:///./finspark.db
# Postgres example:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/finspark

# ── Auth / JWT ─────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── OpenAI / LLM ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Embedding model ────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu           # cpu | cuda | mps

# ── External integrations ──────────────────────────────────────────────────────
# Add provider-specific keys here as integrations are wired up
# STRIPE_SECRET_KEY=sk_test_...
# PLAID_CLIENT_ID=...
# PLAID_SECRET=...

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json                # json | console
